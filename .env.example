# Calqulate — mobile app environment.
# Copy to `.env` and fill in. Only EXPO_PUBLIC_* vars reach the client bundle,
# and everything in this file does — so never put a secret here. Server secrets
# (RevenueCat REST key, Firebase service account, Supabase service role) belong
# in server/.env, which is never bundled.

# Backend base URL. Leave blank to run the app fully offline — every API call
# degrades gracefully rather than erroring.
EXPO_PUBLIC_API_URL=http://localhost:4000

# RevenueCat public SDK keys (safe to ship; they are per-platform and public).
# RevenueCat dashboard → Project settings → API keys → Public app-specific keys.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Supabase. Dashboard → Project Settings → API.
# The anon key is public by design; Row Level Security in supabase/schema.sql is
# what protects the data. NEVER put the service_role key in this file.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated emails that get admin access in the app (full feature unlock
# for testing). Real authority is profiles.is_admin in Postgres, set by
# supabase/schema.sql — this only controls the in-app shortcut.
EXPO_PUBLIC_ADMIN_EMAILS=you@example.com
