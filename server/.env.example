# ---------------------------------------------------------------------------
# Calqulate admin server — copy to `.env` and fill in.
# Every variable the server reads is listed here. Nothing else is consulted.
# ---------------------------------------------------------------------------

# HTTP port for the API + admin panel. Default: 4000
PORT=4000

# --- Supabase (the database) -----------------------------------------------
# Both values live in one place:
#   Supabase Dashboard → your project → Project Settings (gear, bottom left)
#     → API → "Project URL"  and  "Project API keys → service_role"
#
# SUPABASE_URL looks like https://abcdefghijklmnop.supabase.co
SUPABASE_URL=
#
# The service_role key is hidden behind a "Reveal" button. It BYPASSES every
# row-level-security policy, which is why this server can read all profiles and
# is the only thing allowed to write is_pro. Treat it like a root password:
# server-side only, never in the mobile app, never in a browser, never in git.
# (The app uses the *anon* key instead — that is the one that is safe to ship.)
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin panel login -----------------------------------------------------
# There is no admin password here any more. You sign in with a real Calqulate
# account (Supabase Auth), and access is granted if profiles.is_admin = true OR
# the email appears in this comma-separated allowlist. An allowlisted email is
# promoted to is_admin = true on first successful sign-in, which is how the
# first owner bootstraps without opening the SQL editor.
ADMIN_EMAILS=you@example.com

# Secret used to HMAC-sign the session cookie. Any long random string.
# Rotating it invalidates every open session.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-32-plus-random-bytes

# --- RevenueCat ------------------------------------------------------------
# Shared secret RevenueCat sends verbatim in the `Authorization` header of
# every webhook POST. Configure the same value in RevenueCat →
# Project settings → Integrations → Webhooks → Authorization header.
# If unset, the webhook route refuses every request (fail closed).
REVENUECAT_WEBHOOK_AUTH=whsec_replace_me

# RevenueCat v2 REST API key (Project settings → API keys → "V2 secret key").
# Used when an admin grants/revokes Pro from the panel so the change reaches
# the user's device. If unset, grant/revoke only updates Supabase and the panel
# says so explicitly.
REVENUECAT_API_KEY=
# Your RevenueCat project id (starts with `proj`). Required alongside the key.
REVENUECAT_PROJECT_ID=
# Entitlement id that means "Pro". Matches ENTITLEMENT in src/lib/billing.ts.
REVENUECAT_ENTITLEMENT_ID=pro

# --- Firebase Cloud Messaging (HTTP v1) ------------------------------------
# From the service-account JSON: Firebase console → Project settings →
# Service accounts → Generate new private key.
# All three must be present or push sending degrades to a recorded dry run.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the whole PEM on one line with literal \n escapes, wrapped in quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
