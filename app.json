{
  "expo": {
    "name": "Calqulate Vitals",
    "slug": "calqulate",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "calqulate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#FFFFFF",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.calqulate.app",
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.calqulate.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#0F9F73",
          "defaultChannel": "reminders"
        }
      ],
      "expo-secure-store",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
